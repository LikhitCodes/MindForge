{
  "name": "mindforge",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "start": "concurrently \"npm run ui\" \"npm run app\"",
    "ui": "cd renderer && npm run dev",
    "app": "wait-on http://localhost:5174 && cross-env NODE_ENV=development electron .",
    "build": "cd renderer && npm run build && electron-builder",
    "seed": "node seed.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "active-win": "^7.7.2",
    "dotenv": "^16.3.0",
    "express": "^4.18.0",
    "googleapis": "^171.4.0",
    "ws": "^8.0.0"
  },
  "devDependencies": {
    "concurrently": "^8.0.0",
    "cross-env": "^7.0.0",
    "electron": "^41.0.3",
    "wait-on": "^7.0.0"
  }
}
